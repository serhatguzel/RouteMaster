<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <!-- Roles Table -->
    <changeSet id="1" author="routemaster">
        <createTable tableName="roles">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints primaryKey="true" primaryKeyName="rolesPK"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Users Table -->
    <changeSet id="2" author="routemaster">
        <createTable tableName="users">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints primaryKey="true" primaryKeyName="usersPK"/>
            </column>
            <column name="username" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- User Roles Join Table -->
    <changeSet id="3" author="routemaster">
        <createTable tableName="user_roles">
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_user_roles_user" referencedTableName="users" referencedColumnNames="id"/>
            </column>
            <column name="role_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_user_roles_role" referencedTableName="roles" referencedColumnNames="id"/>
            </column>
        </createTable>
        <addPrimaryKey columnNames="user_id, role_id" tableName="user_roles"/>
    </changeSet>

    <!-- Locations Table -->
    <changeSet id="4" author="routemaster">
        <createTable tableName="locations">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints primaryKey="true" primaryKeyName="locationsPK"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="city" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="country" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="location_code" type="VARCHAR(10)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Transportations Table -->
    <changeSet id="5" author="routemaster">
        <createTable tableName="transportations">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints primaryKey="true" primaryKeyName="transportationsPK"/>
            </column>
            <column name="origin_location_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_transportation_origin" referencedTableName="locations" referencedColumnNames="id"/>
            </column>
            <column name="destination_location_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_transportation_destination" referencedTableName="locations" referencedColumnNames="id"/>
            </column>
            <column name="transportation_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Transportation Operation Days Table -->
    <changeSet id="6" author="routemaster">
        <createTable tableName="transportation_operation_days">
            <column name="transportation_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_op_days_transportation" referencedTableName="transportations" referencedColumnNames="id"/>
            </column>
            <column name="operation_day" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
